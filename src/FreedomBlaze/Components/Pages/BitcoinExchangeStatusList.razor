@using FreedomBlaze.Models
@using MudBlazor

<div class="d-flex flex-wrap gap-2 pa-3">
    @foreach (var exchange in ExchangeStatusList)
    {
        <MudChip T="string"
                 Icon="@(exchange.IsExchangeAvailable ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                 Color="@(exchange.IsExchangeAvailable ? Color.Success : Color.Error)"
                 Variant="Variant.Outlined" Size="Size.Small">
            @exchange.ExchangeName
        </MudChip>
    }
</div>

@code {
    [Parameter]
    public List<BitcoinExchangeStatusModel> ExchangeStatusList { get; set; } = new();
}
