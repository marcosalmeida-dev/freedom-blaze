@page "/Error"
@using System.Diagnostics

<PageSeo Title="Error | Freedom Blaze" NoIndex="true" />

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudAlert Severity="Severity.Error" Icon="@Icons.Material.Filled.ErrorOutline" Class="mb-4">
        An error occurred while processing your request.
    </MudAlert>

    @if (ShowRequestId)
    {
        <MudText Typo="Typo.body2" Class="mb-4">
            Request ID: <code>@RequestId</code>
        </MudText>
    }

    <MudButton Href="/satsconverter" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Home">
        Return Home
    </MudButton>
</MudContainer>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
