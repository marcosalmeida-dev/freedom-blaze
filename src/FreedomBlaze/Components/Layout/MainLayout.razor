@using FreedomBlaze.Interfaces
@using FreedomBlaze.Models
@using FreedomBlaze.Services
@using FreedomBlaze.WebClients
@using Microsoft.AspNetCore.Localization
@using System.Globalization

@inherits LayoutComponentBase

<MudThemeProvider @ref="@_mudThemeProvider" @bind-IsDarkMode="@ThemeManager.IsDarkMode" Theme="_theme" />
<MudSnackbarProvider />
<MudPopoverProvider />
<MudDialogProvider
    FullWidth="true"
    CloseButton="true"
    CloseOnEscapeKey="true"
    MaxWidth="MaxWidth.ExtraSmall"
    Position="DialogPosition.Center" />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" aria-label="Toggle navigation menu" />
        <MudImage Src="/img/freedom-blaze-logo-3-4-small.png" Class="app-icon" Alt="Freedom Blaze logo" Height="40" Width="30" />
        <MudText Typo="Typo.h5" Class="app-name ml-3">Freedom Blaze</MudText>
        <MudSpacer />

        <MudSelect T="string" @bind-Value="CultureService.CurrencyCultureName"
                   Variant="Variant.Text" Margin="Margin.Dense"
                   Class="appbar-currency-select" PopoverClass="currency-dropdown"
                   AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter"
                   DisableUnderLine="true" aria-label="Select currency">
            @foreach (var currency in CurrencyModel.CurrencyListStatic)
            {
                <MudSelectItem Value="@currency.CultureName" @key="@currency.CultureName">
                    <img src="@currency.FlagSvgPath" height="14" class="mr-1" />
                    @currency.Value (@currency.Symbol)
                </MudSelectItem>
            }
        </MudSelect>
        @if (_btcPriceCulture != null)
        {
            <MudChip T="string" Icon="@Icons.Material.Filled.CurrencyBitcoin"
                     Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small"
                     OnClick="@(() => WriteTextAsync(_btcPriceCulture))" Class="ml-2">
                @_btcPriceCulture
            </MudChip>
        }
        <MudIconButton Icon="@(ThemeManager.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="ThemeManager.ToggleTheme"
                       aria-label="Toggle dark mode" Class="ml-1" />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="DrawerVariant.Temporary">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer>
            <ErrorBoundary>
                <ChildContent>@Body</ChildContent>
                <ErrorContent Context="ex">
                    <MudAlert Severity="Severity.Error" Class="ma-4">
                        An unexpected error occurred. Please refresh the page.
                    </MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@inject IJSRuntime JS
@inject ILogger<MainLayout> Logger
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject IHttpContextAccessor ContextAccessor
@inject CultureService CultureService
@inject ISnackbar Snackbar
@inject AppState AppState
@inject ThemeManager ThemeManager

@code {
    MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#f7931a",
            Secondary = Colors.BlueGray.Darken1,
            AppbarBackground = "#1a1a2e",
            Background = "#f8fafd",
            Surface = Colors.Shades.White,
            DrawerBackground = "#1a1a2e",
            DrawerText = Colors.Shades.White,
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#f7931a",
            Secondary = Colors.Green.Lighten1,
            AppbarBackground = "#0d0d0f",
            Background = "#13131a",
            Surface = "#1e1e2a",
            DrawerBackground = "#0d0d0f",
        }
    };

    private MudThemeProvider _mudThemeProvider = null!;

    private DotNetObjectReference<MainLayout>? _dotNetRef;

    private string _darkModeCookieName = "darkModeCookie";

    private bool _drawerOpen = false;

    private string? _btcPriceCulture;

    private EventHandler _cultureChangedHandler = default!;

    CancellationTokenSource cancellationTokenSource = new CancellationTokenSource();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _cultureChangedHandler = (_, _) => OnCurrencyChanged();
                CultureService.OnCurrencyCultureChanged += _cultureChangedHandler;
                AppState.OnChange += OnAppStateChanged;
                ThemeManager.OnThemeChanged += ThemeChanged;

                _dotNetRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("darkModeHelper.watchSystemPreference", cancellationTokenSource.Token, _dotNetRef);
                var savedDarkMode = await JS.InvokeAsync<string>("cookieHelper.getCookie", cancellationTokenSource.Token, _darkModeCookieName);
                if (!string.IsNullOrEmpty(savedDarkMode))
                {
                    ThemeManager.IsDarkMode = bool.Parse(savedDarkMode);
                }
                else
                {
                    ThemeManager.IsDarkMode = await JS.InvokeAsync<bool>("darkModeHelper.getSystemPreference", cancellationTokenSource.Token);
                }

                await InvokeAsync(StateHasChanged);
            }
            catch (JSDisconnectedException) { }
            catch (OperationCanceledException) { }
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    [JSInvokable]
    public Task SystemPreferenceChanged(bool isDark)
    {
        ThemeManager.IsDarkMode = isDark;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task ThemeChanged(bool isDarkMode)
    {
        try
        {
            await JS.InvokeVoidAsync("cookieHelper.setCookie", cancellationTokenSource.Token, _darkModeCookieName, isDarkMode.ToString(), 365);
        }
        catch (JSDisconnectedException) { }
        catch (OperationCanceledException) { }
    }

    private async Task OnAppStateChanged()
    {
        var currentCurrencyInfo = CurrencyModel.GetCurrencyList(CultureService.CurrencyCultureName).FirstOrDefault();
        if (currentCurrencyInfo is null || AppState.BitcoinExchangeRate is null)
            return;

        _btcPriceCulture = (currentCurrencyInfo.CurrencyRateInUSD * AppState.BitcoinExchangeRate.BitcoinRateInUSD).ToString("C", currentCurrencyInfo.CultureInfo);

        await InvokeAsync(StateHasChanged);
    }

    private void OnCurrencyChanged()
    {
        var uri = new Uri(Navigation.Uri).GetComponents(UriComponents.PathAndQuery, UriFormat.Unescaped);
        var uriEscaped = Uri.EscapeDataString(uri);

        Navigation.NavigateTo(
            $"Culture/Set?culture={CultureService.CurrencyCultureName}&redirectUri={uriEscaped}",
            forceLoad: true);
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void SnackMessage(string message, string position = Defaults.Classes.Position.TopCenter, Severity severity = Severity.Info)
    {
        Snackbar.Clear();
        Snackbar.Configuration.SnackbarVariant = Variant.Text;
        Snackbar.Configuration.PositionClass = position;
        Snackbar.Add(message, severity);
    }

    private async Task WriteTextAsync(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            SnackMessage($"{text} Copied to clipboard!", position: Defaults.Classes.Position.TopRight, severity: Severity.Success);
        }
        catch (Exception ex)
        {
            SnackMessage($"Error copying to clipboard: {ex.Message}", severity: Severity.Error);
        }
    }

    public void Dispose()
    {
        CultureService.OnCurrencyCultureChanged -= _cultureChangedHandler;
        AppState.OnChange -= OnAppStateChanged;
        ThemeManager.OnThemeChanged -= ThemeChanged;

        _dotNetRef?.Dispose();

        if (cancellationTokenSource != null && !cancellationTokenSource.IsCancellationRequested)
        {
            cancellationTokenSource.Cancel();
            cancellationTokenSource.Dispose();
        }
    }
}
