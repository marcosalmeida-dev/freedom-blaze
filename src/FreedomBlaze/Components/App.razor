@using Microsoft.AspNetCore.Localization
@using System.Globalization
@inject IConfiguration Configuration

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f7931a" />
    <meta name="color-scheme" content="light dark" />
    <meta name="keywords" content="bitcoin, satoshi, sats, sats converter, BTC to USD, bitcoin price, lightning network, bitcoin news, cryptocurrency converter" />
    <meta name="author" content="Freedom Blaze" />
    <meta name="robots" content="index, follow" />
    <meta name="application-name" content="Freedom Blaze" />
    <base href="/" />

    @* Per-page <title>, description and canonical are set by the PageSeo component via <HeadOutlet> below. *@

    <!-- Open Graph / social sharing defaults (per-page title, description & url are set via PageSeo) -->
    <meta property="og:site_name" content="Freedom Blaze" />
    <meta property="og:locale" content="@OgLocale" />
    <meta property="og:image" content="@BaseUrl/img/freedom-blaze-logo-3-4.png" />
    <meta property="og:image:alt" content="Freedom Blaze logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="@BaseUrl/img/freedom-blaze-logo-3-4.png" />

    <!-- Icons & installable web-app manifest -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/img/freedom-blaze-logo-3-4-small.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Freedom Blaze" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="/app.css" rel="stylesheet" asp-append-version="true" />

    <HeadOutlet @rendermode="InteractiveServer" />

    <!-- Structured data: tells search engines who publishes this site and what it is. -->
    @((MarkupString)StructuredData)
    <script>
        // Apply dark mode before first paint to prevent FOUC
        (function () {
            var c = document.cookie.split(';').find(function (s) { return s.trim().startsWith('darkModeCookie='); });
            if (c && c.split('=')[1].trim() === 'True') {
                document.documentElement.classList.add('dark-mode-preload');
            }
        })();
    </script>
    <!-- Microsoft Clarity -->
    @if (!string.IsNullOrWhiteSpace(ClarityProjectId))
    {
        <script type="text/javascript">
                (function(c,l,a,r,i,t,y){
                c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
                t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
                y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
                })(window, document, "clarity", "script", "@ClarityProjectId");
        </script>
    }
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="/js/app.js" asp-append-version="true"></script>
</body>

</html>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private string? ClarityProjectId => Configuration["MicrosoftClarity:ProjectId"];

    // Absolute site origin built from the live request, so canonical/OG/structured-data URLs are
    // correct in every environment (no hard-coded domain). Falls back to the configured BaseUrl.
    private string BaseUrl => HttpContext is not null
        ? $"{HttpContext.Request.Scheme}://{HttpContext.Request.Host}"
        : (Configuration["BaseUrl"]?.TrimEnd('/') ?? string.Empty);

    // OG locale wants an underscore form (e.g. en_US) rather than the BCP-47 hyphen form.
    private string OgLocale => CultureInfo.CurrentUICulture.Name.Replace('-', '_');

    private string StructuredData
    {
        get
        {
            var payload = new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@graph"] = new object[]
                {
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "Organization",
                        ["@id"] = $"{BaseUrl}/#organization",
                        ["name"] = "Freedom Blaze",
                        ["url"] = $"{BaseUrl}/",
                        ["logo"] = $"{BaseUrl}/img/freedom-blaze-logo-3-4.png"
                    },
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "WebSite",
                        ["@id"] = $"{BaseUrl}/#website",
                        ["name"] = "Freedom Blaze",
                        ["url"] = $"{BaseUrl}/",
                        ["description"] = "Real-time Bitcoin Satoshi (Sats) converter with multi-currency support and live exchange rates.",
                        ["publisher"] = new Dictionary<string, object?> { ["@id"] = $"{BaseUrl}/#organization" },
                        ["inLanguage"] = CultureInfo.CurrentUICulture.Name
                    }
                }
            };

            var json = System.Text.Json.JsonSerializer.Serialize(payload);
            return $"<script type=\"application/ld+json\">{json}</script>";
        }
    }

    protected override void OnInitialized()
    {
        HttpContext?.Response.Cookies.Append(
            CookieRequestCultureProvider.DefaultCookieName,
            CookieRequestCultureProvider.MakeCookieValue(
                new RequestCulture(
                    CultureInfo.CurrentCulture,
                    CultureInfo.CurrentUICulture)));
    }
}
