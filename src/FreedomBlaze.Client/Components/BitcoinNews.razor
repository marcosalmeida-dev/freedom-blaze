@page "/bitcoinnews"
@rendermode InteractiveAuto

@using System.Globalization
@using FreedomBlaze.Client.Helpers
@using FreedomBlaze.Client.Services
@using FreedomBlaze.Models

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudGrid Justify="Justify.SpaceBetween" Class="mb-2" AlignItems="Center.Center">
        <MudItem>
            <MudText Typo="Typo.h5">Bitcoin News</MudText>
        </MudItem>
        <MudItem>
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary"
                           aria-label="Refresh news"
                           Disabled="_loading" OnClick="RefreshNewsAsync" />
        </MudItem>
    </MudGrid>

    @if (_loading)
    {
        <MudGrid Justify="Justify.Center" Class="mt-4">
            @for (var i = 0; i < 6; i++)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Class="d-flex flex-column h-100">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="150px" />
                        <MudCardContent>
                            <MudSkeleton Width="90%" />
                            <MudSkeleton Width="60%" Class="mt-1" />
                            <MudSkeleton Width="40%" Class="mt-1" />
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else if (_newsArticles?.Count > 0)
    {
        <MudGrid Justify="Justify.Center" Class="mt-4">
            @foreach (var article in _newsArticles)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Class="d-flex flex-column h-100" Style="height: 100%;">
                        @if (!string.IsNullOrEmpty(article.NewsThumbImg))
                        {
                            <MudCardMedia Image="@article.NewsThumbImg" Height="150" />
                        }
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h5">@(article.Title.Length > 50 ? article.Title[..50] + "..." : article.Title)</MudText>
                                <MudText Typo="Typo.body1" Color="Color.Secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.Public" Class="mt-1 me-1" Size="Size.Small" />
                                    @article.Source
                                </MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Class="mt-1 me-1" Size="Size.Small" />
                                    @article.SourceRegion
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent Class="flex-grow-1">
                            <MudText>@(article.Text.Length > 150 ? article.Text[..150] + "..." : article.Text)</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @article.Date.ToString("MMMM dd, yyyy")
                            </MudText>
                        </MudCardContent>
                        <MudCardActions Class="mt-auto">
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@article.ArticleLinkUrl" Target="_blank">Read More</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudGrid Justify="Justify.Center" Class="mt-8">
            <MudAlert Severity="Severity.Info">No news found!</MudAlert>
        </MudGrid>
    }
</MudContainer>


@inject ISnackbar Snackbar
@inject BitcoinNewsService Service

@code {
    private List<NewsArticleModel> _newsArticles = [];
    private bool _loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadNewsAsync();
        await base.OnInitializedAsync();
    }

    private async Task LoadNewsAsync()
    {
        try
        {
            _loading = true;
            _newsArticles = await Service.GetBtcNews();
        }
        catch
        {
            Snackbar.SnackMessage("Some error occurred while trying to get bitcoin news, sorry!", Defaults.Classes.Position.TopCenter, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshNewsAsync()
    {
        await LoadNewsAsync();
    }
}
