@page "/bitcoinnews"
@rendermode InteractiveAuto

<PageTitle>Bitcoin News</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
              Spacing="3" Class="mb-4">
        <div>
            <MudText Typo="Typo.h5">Bitcoin News</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Around the world · @SelectedDate.ToString("MMMM d, yyyy")@(IsToday ? " · today" : string.Empty)
            </MudText>
        </div>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            @* The width constraint lives on this wrapper (input only). PickerVariant.Dialog renders
               the calendar as a centered modal, so it is never clipped on mobile or desktop. *@
            <div style="width: 200px; max-width: 100%;">
                <MudDatePicker Date="_selectedDate" DateChanged="OnDateChangedAsync"
                               MinDate="_minDate" MaxDate="_maxDate"
                               PickerVariant="PickerVariant.Dialog"
                               Label="Date" Variant="Variant.Outlined" Margin="Margin.Dense"
                               DateFormat="MMM d, yyyy" Editable="true" Disabled="_loading" />
            </div>
            <MudTooltip Text="@(IsToday ? "Fetch the latest news" : "Re-fetch this day's news")">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary"
                               aria-label="Refresh news" Disabled="_loading" OnClick="RefreshAsync" />
            </MudTooltip>
        </MudStack>
    </MudStack>

    @if (_loading)
    {
        <MudGrid>
            @for (var i = 0; i < SkeletonCount; i++)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Class="d-flex flex-column" Style="height: 100%;" Elevation="2">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="160px" />
                        <MudCardContent>
                            <MudSkeleton Width="40%" Class="mb-2" />
                            <MudSkeleton Width="95%" />
                            <MudSkeleton Width="80%" Class="mt-1" />
                            <MudSkeleton Width="60%" Class="mt-1" />
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else if (_articles.Count > 0)
    {
        <MudGrid>
            @foreach (var article in _articles)
            {
                <MudItem xs="12" sm="6" md="4">
                    <NewsArticleCard Article="article" />
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="4" Class="mt-12">
            <MudIcon Icon="@Icons.Material.Filled.Newspaper" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center">
                No Bitcoin news for @SelectedDate.ToString("MMMM d, yyyy").
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_loading"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshAsync">
                Fetch news for this day
            </MudButton>
        </MudStack>
    }
</MudContainer>
